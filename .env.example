# =========================================================
# .env.example — шаблон змінних оточення
# Скопіюй у .env та заповни реальними значеннями.
# .env НЕ комітиться в git.
# =========================================================

# ---- Django core ----
# Згенерувати новий ключ:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Через nginx-proxy слухаємо http://localhost:8080 — додай у CSRF-довірені:
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ---- Database (PostgreSQL) ----
# Формат URL: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Локально: host=localhost. У docker-compose перевизначається на host=db.
DATABASE_URL=postgres://pms_user:pms_password@localhost:5432/pms_db
# Окремі змінні — використовуються docker-compose (можна не чіпати в локалці):
POSTGRES_DB=pms_db
POSTGRES_USER=pms_user
POSTGRES_PASSWORD=pms_password

# ---- Redis (Celery broker та cache) ----
# Локально: localhost. У docker-compose перевизначається на host=redis.
REDIS_URL=redis://localhost:6379/0

# ---- Nginx (порт хосту для docker-compose, всередині завжди 80) ----
NGINX_PORT=8080

# ---- AI API keys ----
# Заповни тільки той, який реально використовуєш (етап 7).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Email (опційно, для майбутньої функції відновлення паролю) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
